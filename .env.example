# ═════════════════════════════════════════════════════════════════════════════
# TikTok Scraper — Environment Variables
# Salin file ini ke .env dan isi nilai yang sesuai
# cp .env.example .env
# ═════════════════════════════════════════════════════════════════════════════

# ── BACKEND ───────────────────────────────────────────────────────────────

# Mode headless Chrome — WAJIB True di server/Docker (Chrome tidak muncul)
TIKTOK_HEADLESS=True

# Tambah --no-sandbox ke Chrome — WAJIB True jika container berjalan sebagai root
# (Default di Docker; False untuk desktop/Windows lokal)
CHROME_NO_SANDBOX=False

# Mode sentiment analisis
# rule_only = cepat, tidak butuh GPU/torch (default Docker)
# hybrid    = pakai IndoBERT (butuh torch, image lebih besar)
SENTIMENT_MODE=rule_only

# Timeout subprocess (detik)
TIKTOK_VIDEO_TIMEOUT=900
TIKTOK_PROFILE_TIMEOUT=300
TIKTOK_CHECKPOINT_TIMEOUT=3600

# Kelas scraper yang dipakai (sesuaikan dengan versi engine)
TIKTOK_SCRAPER_CLASS=TikTokScraperV58

# CORS — biarkan * untuk dev, isi domain untuk production
# Contoh: CORS_ORIGINS=https://app.yourdomain.com
CORS_ORIGINS=*

# ── FRONTEND ──────────────────────────────────────────────────────────────

# URL backend dari sisi SERVER Next.js (untuk rewrites proxy, bukan browser)
# Di Docker: pakai nama service Docker
BACKEND_URL=http://backend:8001

# URL backend dari sisi BROWSER (opsional)
# Jika di-set, browser langsung connect ke backend (bypass proxy)
# Kosongkan jika ingin pakai proxy Next.js (lebih aman, hanya port 3000 exposed)
# Contoh untuk akses langsung: NEXT_PUBLIC_API_URL=http://192.168.1.10:8001
NEXT_PUBLIC_API_URL=
