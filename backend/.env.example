# ── KONFIGURASI BRIDGE FASTAPI ────────────────────────────────
# Default engine ada di backend/engine/. Override hanya jika engine di tempat lain:
# TIKTOK_ENGINE_DIR=C:\Users\USER\folder-engine-tiktok

# Timeout subprocess (detik)
TIKTOK_VIDEO_TIMEOUT=900
TIKTOK_PROFILE_TIMEOUT=300
TIKTOK_DEBUG_HTML=true

# ── KONFIGURASI ENGINE ────────────────────────────────────────
# CATATAN: engine membaca .env dari folder-nya sendiri (backend/engine/.env),
# jadi sebaiknya buat juga .env di dalam engine/. Variabel di bawah untuk referensi:
# TIKTOK_HEADLESS=False        (True saat deploy ke server tanpa display)
# SENTIMENT_MODE=hybrid        (hybrid | ml_only | rule_only)
# GEMINI_ENABLED=False
# TIKTOK_MAX_COMMENTS=100
# TIKTOK_PROXY=
